# Stage 1: Build
FROM oven/bun:1.1 as build
WORKDIR /usr/src/app

COPY . .
RUN bun install

# Build the frontend using the custom build script
WORKDIR /usr/src/app/apps/dashboard-frontend
RUN bun run build

# Stage 2: Serve with Nginx
FROM nginx:alpine
# Copy built files from the 'dist' folder generated by build.ts
COPY --from=build /usr/src/app/apps/dashboard-frontend/dist /usr/share/nginx/html
# Copy a basic nginx config if needed, or use default
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
